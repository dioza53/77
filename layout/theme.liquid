<!DOCTYPE html>
<html lang="he" dir="rtl" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#1a1a1a">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700;900&family=Playfair+Display:wght@400;700;900&display=swap">

    <title>
      {{ page_title }}
      {%- if current_tags -%}{%- assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags -}}{%- endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{%- endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{%- endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'lumibrace-tailwind.css' | asset_url | stylesheet_tag }}

    <!-- Tailwind CDN Fallback for newly added utility classes -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              charcoal: '#1a1a1a',
              gold: '#D4AF37',
              pearl: '#F8F6F0',
              'gold-soft': 'rgba(212, 175, 55, 0.1)',
            },
            fontFamily: {
              sans: ['Heebo', 'sans-serif'],
              serif: ['Playfair Display', 'serif'],
            }
          }
        }
      }
    </script>

    <script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>

  </head>

  <body class="template-{{ template.name | handle }}">
    <a class="skip-to-content-link" href="#MainContent">דלג לתוכן</a>

    {% sections 'header-group' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script src="{{ 'cart.js' | asset_url }}" defer></script>
  </body>
</html>
