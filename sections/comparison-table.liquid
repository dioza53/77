{% comment %}
  LumiBrace Comparison Table Section — high-converting feature comparison list
{% endcomment %}

<section class="py-24 bg-charcoal relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-[500px] bg-gold/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
      <h2 class="text-3xl md:text-5xl font-black text-pearl tracking-tight">{{ section.settings.heading }}</h2>
      <p class="text-pearl/60 text-lg max-w-2xl mx-auto">{{ section.settings.subheading }}</p>
    </div>

    <div class="max-w-4xl mx-auto overflow-hidden rounded-[2rem] border border-pearl/10 bg-black/40 backdrop-blur-md shadow-2xl">
      <div class="overflow-x-auto">
        <table class="w-full text-right whitespace-nowrap md:whitespace-normal">
          <thead>
            <tr class="border-b border-pearl/10">
              <th class="p-6 font-black text-xs md:text-sm text-pearl/40 uppercase tracking-widest w-1/3">קריטריון השוואה</th>
              <th class="p-6 text-center w-1/3 bg-gold/5 border-x border-gold/10">
                <div class="inline-flex flex-col items-center gap-1">
                  <span class="text-gold font-black text-lg md:text-xl">{{ shop.name | default: 'LumiBrace' }}</span>
                  <span class="text-[10px] font-bold text-gold/60 uppercase tracking-widest bg-gold/10 px-2 py-0.5 rounded-full">הבחירה שלנו</span>
                </div>
              </th>
              <th class="p-6 text-center w-1/3 text-pearl/40 font-bold">מתחרים זולים</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-pearl/5">
            {%- for block in section.blocks -%}
              <tr class="hover:bg-pearl/5 transition-colors group" {{ block.shopify_attributes }}>
                <td class="p-6 font-bold text-sm md:text-base text-pearl">{{ block.settings.feature }}</td>
                
                <td class="p-6 text-center bg-gold/5 border-x border-gold/10 relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                  <div class="relative z-10 flex flex-col items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-gold/20 flex items-center justify-center text-gold shadow-[0_0_10px_rgba(212,175,55,0.3)]">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><path d="M20 6 9 17l-5-5"></path></svg>
                    </div>
                    <span class="font-bold text-xs md:text-sm text-pearl">{{ block.settings.lumi_desc }}</span>
                  </div>
                </td>

                <td class="p-6 text-center opacity-50 group-hover:opacity-80 transition-opacity">
                  <div class="flex flex-col items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-red-500/10 flex items-center justify-center text-red-400">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
                    </div>
                    <span class="text-xs md:text-sm text-pearl">{{ block.settings.other_desc }}</span>
                  </div>
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "למה לבחור ב-LumiBrace?" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "אל תתפשרו על האיכות כשמדובר בזיכרונות שלכם. הנה ההבדל בינינו לבין חיקויים זולים." }
  ],
  "blocks": [
    {
      "type": "comparison_row",
      "name": "Comparison Feature",
      "settings": [
        { "type": "text", "id": "feature", "label": "Feature Name" },
        { "type": "text", "id": "lumi_desc", "label": "LumiBrace Feature Description" },
        { "type": "text", "id": "other_desc", "label": "Competitor Feature Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        { "type": "comparison_row", "settings": { "feature": "חומר הגלם", "lumi_desc": "פלדת אל-חלד 316L (אינה מחלידה)", "other_desc": "סגסוגת מתכת פשוטה (משחירה מהר)" } },
        { "type": "comparison_row", "settings": { "feature": "איכות העדשה", "lumi_desc": "קריסטל HD אופטי מלוטש", "other_desc": "עדשת פלסטיק מטושטשת" } },
        { "type": "comparison_row", "settings": { "feature": "עמידות במים", "lumi_desc": "עמידות מלאה בים, מקלחת וספורט", "other_desc": "אסור להרטיב - מחליד במגע עם מים" } },
        { "type": "comparison_row", "settings": { "feature": "חדות התמונה", "lumi_desc": "חריטת ננו-לייזר מגה חדה", "other_desc": "הדפסה כהה, מפוקסלת ולא ברורה" } },
        { "type": "comparison_row", "settings": { "feature": "מארז מתנה", "lumi_desc": "קופסת פרימיום יוקרתית וכרטיס ברכה", "other_desc": "שקית ניילון פשוטה וזולה" } }
      ]
    }
  ]
}
{% endschema %}
