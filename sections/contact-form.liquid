{% comment %}
  LumiBrace Contact Form Section — Native Shopify contact form with premium dark card layout
{% endcomment %}

<section class="py-24 bg-charcoal relative overflow-hidden" id="contact">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gold/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10 max-w-4xl">
    <div class="bg-black/40 backdrop-blur-md border border-gold/20 rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(212,175,55,0.1)_0%,_transparent_50%)] pointer-events-none"></div>
      
      <div class="relative z-10">
        <div class="text-center mb-12 space-y-4">
          <span class="px-4 py-1.5 rounded-full bg-gold/10 text-gold text-xs font-bold uppercase tracking-widest inline-block mb-2 border border-gold/20 shadow-[0_0_15px_rgba(212,175,55,0.2)]">{{ section.settings.badge }}</span>
          <h2 class="text-3xl md:text-4xl font-black text-pearl tracking-tight">{{ section.settings.heading }}</h2>
          <p class="text-pearl/60 text-base max-w-lg mx-auto">{{ section.settings.subheading }}</p>
        </div>

        {%- form 'contact', class: 'space-y-6 max-w-2xl mx-auto' -%}
          {%- if form.posted_successfully? -%}
            <div class="text-center py-8">
              <div class="w-20 h-20 mx-auto rounded-full bg-gold/10 flex items-center justify-center text-gold mb-6 border border-gold/20 shadow-[0_0_20px_rgba(212,175,55,0.2)]">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><path d="M20 6 9 17l-5-5"></path></svg>
              </div>
              <h3 class="text-2xl font-bold text-pearl mb-2">ההודעה נשלחה בהצלחה!</h3>
              <p class="text-pearl/60">תודה שפניתם אלינו. צוות LumiBrace ידאג לחזור אליכם במייל בהקדם האפשרי.</p>
            </div>
          {%- else -%}
            
            {%- if form.errors -%}
              <div class="bg-red-500/10 border border-red-500/30 rounded-2xl p-4 text-red-400 text-sm text-center">
                שגיאה בשליחת הטופס. אנא ודאו שכל השדות מלאים בצורה תקינה.
              </div>
            {%- endif -%}

            <div class="space-y-6">
              <div>
                <label class="block text-pearl/80 text-sm font-bold mb-2 text-right" for="contact-name">שם מלא</label>
                <input 
                  type="text" 
                  id="contact-name" 
                  name="contact[name]" 
                  value="{{ form.name }}"
                  placeholder="איך קוראים לכם?" 
                  required 
                  class="w-full bg-pearl/5 border border-pearl/10 rounded-2xl px-6 py-4 text-pearl placeholder:text-pearl/30 focus:border-gold focus:ring-1 focus:ring-gold outline-none transition-all text-right"
                >
              </div>

              <div>
                <label class="block text-pearl/80 text-sm font-bold mb-2 text-right" for="contact-email">אימייל לחזרה</label>
                <input 
                  type="email" 
                  id="contact-email" 
                  name="contact[email]" 
                  value="{{ form.email }}"
                  placeholder="כתובת המייל שלכם..." 
                  required 
                  class="w-full bg-pearl/5 border border-pearl/10 rounded-2xl px-6 py-4 text-pearl placeholder:text-pearl/30 focus:border-gold focus:ring-1 focus:ring-gold outline-none transition-all text-right dir-ltr"
                >
              </div>

              <div>
                <label class="block text-pearl/80 text-sm font-bold mb-2 text-right" for="contact-message">תוכן ההודעה</label>
                <textarea 
                  id="contact-message" 
                  name="contact[body]" 
                  placeholder="מה תרצו לשאול אותנו או במה נוכל לעזור?" 
                  required 
                  rows="4"
                  class="w-full bg-pearl/5 border border-pearl/10 rounded-2xl px-6 py-4 text-pearl placeholder:text-pearl/30 focus:border-gold focus:ring-1 focus:ring-gold outline-none transition-all text-right resize-none"
                >{{ form.body }}</textarea>
              </div>

              <button type="submit" class="w-full bg-gold text-charcoal font-black rounded-2xl py-4 hover:scale-[1.02] transition-transform shadow-lg shadow-gold/20 flex items-center justify-center gap-2">
                שלחו הודעה <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-send"><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"></path></svg>
              </button>
            </div>

          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "שירות הלקוחות שלנו" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "יש לכם שאלה? אנחנו כאן" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "אנחנו זמינים לכל שאלה, בעיה או בירור לגבי הזמנה. מלאו את הטופס ונחזור אליכם בהקדם." }
  ],
  "presets": [ { "name": "Contact Form" } ]
}
{% endschema %}
