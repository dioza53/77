{% comment %}
  LumiBrace Premium Footer Section — customizable branding, navigation blocks, and copyright
{% endcomment %}

<footer id="contact" class="bg-charcoal pt-20 pb-10 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-full h-px bg-gradient-to-r from-transparent via-gold/20 to-transparent"></div>
  <div class="absolute -top-40 -right-40 w-80 h-80 bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
      
      {% comment %} Brand Info {% endcomment %}
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-6 group inline-flex">
          <div class="w-10 h-10 rounded-xl bg-gold/10 flex items-center justify-center border border-gold/20 group-hover:bg-gold/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles w-5 h-5 text-gold" aria-hidden="true"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path><path d="M20 2v4"></path><path d="M22 4h-4"></path><circle cx="4" cy="20" r="2"></circle></svg>
          </div>
          <span class="text-2xl font-black tracking-tight text-pearl">{{ shop.name | default: 'LUMIBRACE' }}</span>
        </a>
        <p class="text-pearl/40 text-sm leading-relaxed mb-6">{{ section.settings.tagline }}</p>
      </div>

      {% comment %} Quick Links 1 {% endcomment %}
      <div>
        <h4 class="font-black mb-8 uppercase tracking-widest text-[10px] text-gold">למה לבחור בנו</h4>
        <ul class="space-y-4 text-sm text-pearl/60">
          <li><a href="#" class="hover:text-gold transition-colors flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left w-3 h-3"><path d="m15 18-6-6 6-6"></path></svg> איכות ללא פשרות</a></li>
          <li><a href="#" class="hover:text-gold transition-colors flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left w-3 h-3"><path d="m15 18-6-6 6-6"></path></svg> ייצור אישי קפדני</a></li>
          <li><a href="#contact" class="hover:text-gold transition-colors flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left w-3 h-3"><path d="m15 18-6-6 6-6"></path></svg> צרו קשר</a></li>
        </ul>
      </div>

      {% comment %} Quick Links 2 {% endcomment %}
      <div>
        <h4 class="font-black mb-8 uppercase tracking-widest text-[10px] text-gold">קישורים חשובים</h4>
        <ul class="space-y-4 text-sm text-pearl/60">
          {%- for block in section.blocks -%}
          <li><a href="{{ block.settings.link_url }}" class="hover:text-gold transition-colors flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left w-3 h-3"><path d="m15 18-6-6 6-6"></path></svg> {{ block.settings.link_title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      {% comment %} Newsletter {% endcomment %}
      <div>
        <h4 class="font-black mb-8 uppercase tracking-widest text-[10px] text-gold">הצטרפו למועדון שלנו</h4>
        <p class="text-sm text-pearl/40 mb-6">הירשמו וקבלו עדכונים על קולקציות חדשות, מבצעים מיוחדים והצעות ששמורות רק לחברים.</p>
        {% form 'customer', class: 'flex flex-col gap-3' %}
          <input type="email" name="contact[email]" placeholder="האימייל שלכם" required class="bg-pearl/5 border border-pearl/10 rounded-2xl px-6 py-4 text-sm outline-none focus:border-gold transition-colors w-full focus-visible:ring-1 focus-visible:ring-gold text-pearl">
          <button type="submit" class="bg-gold text-charcoal px-8 py-4 rounded-2xl text-sm font-black w-full hover:scale-105 transition-transform shadow-lg shadow-gold/20 focus-visible:ring-2 focus-visible:ring-white outline-none">הרשמה למועדון</button>
        {% endform %}
      </div>

    </div>

    {% comment %} Copyright & Trust {% endcomment %}
    <div class="pt-12 border-t border-pearl/5 flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex flex-col items-center md:items-start gap-2">
        <p class="text-[10px] text-pearl/20 uppercase tracking-widest font-black">© {{ 'now' | date: "%Y" }} {{ shop.name | default: 'LUMIBRACE' }}. כל הזכויות שמורות.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-6 opacity-20 grayscale">
        <div class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check w-4 h-4"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg> <span class="text-[10px] font-bold">SECURE CHECKOUT</span></div>
        <div class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lock w-4 h-4"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg> <span class="text-[10px] font-bold">SSL ENCRYPTED</span></div>
        <div class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card w-4 h-4"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg> <span class="text-[10px] font-bold">PCI COMPLIANT</span></div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "tagline", "label": "Footer Tagline", "default": "צמיד הקרנה יוקרתי המכיל את הרגעים היפים ביותר שלכם. איכות ללא פשרות, עיצוב נצחי ורגש שעובר בכל מבט." }
  ],
  "blocks": [
    {
      "type": "footer_link",
      "name": "Quick Link",
      "settings": [
        { "type": "text", "id": "link_title", "label": "Link Title" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "footer_link", "settings": { "link_title": "תקנון האתר ותנאי שימוש", "link_url": "/" } },
        { "type": "footer_link", "settings": { "link_title": "מדיניות משלוחים והחזרות", "link_url": "/" } },
        { "type": "footer_link", "settings": { "link_title": "שירות לקוחות", "link_url": "#contact" } }
      ]
    }
  ]
}
{% endschema %}
