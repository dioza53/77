{% comment %}
  LumiBrace Premium Gift Experience Section — Interactive 3D floating box & card, with custom lists
{% endcomment %}

<section class="py-24 bg-charcoal relative overflow-hidden" id="gift">
  <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <div class="space-y-8 text-right order-2 lg:order-1">
        <div>
          <span class="px-4 py-1.5 rounded-full bg-gold/10 text-gold text-xs font-bold uppercase tracking-widest inline-block mb-4 border border-gold/20 shadow-[0_0_15px_rgba(212,175,55,0.2)]">{{ section.settings.badge }}</span>
          <h2 class="text-4xl md:text-5xl font-black text-pearl tracking-tight leading-tight mb-6">{{ section.settings.heading | newline_to_br }}</h2>
          <p class="text-pearl/60 text-lg leading-relaxed">{{ section.settings.description }}</p>
        </div>

        <div class="space-y-4">
          {%- for block in section.blocks -%}
            <div class="bg-pearl/5 border border-pearl/10 p-6 rounded-2xl flex gap-6 items-start hover:border-gold/30 hover:bg-gold/5 transition-all duration-300 group" {{ block.shopify_attributes }}>
              <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center shrink-0 border border-gold/20 group-hover:scale-110 transition-transform">
                <span class="text-xl">{%- if forloop.index == 1 -%}❤️{%- elsif forloop.index == 2 -%}🎂{%- else -%}💍{%- endif -%}</span>
              </div>
              <div>
                <h4 class="text-pearl font-bold text-lg mb-2">{{ block.settings.title }}</h4>
                <p class="text-pearl/60 text-sm leading-relaxed">{{ block.settings.description }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="relative w-full aspect-square md:aspect-[4/5] rounded-[2.5rem] overflow-hidden bg-black border border-pearl/10 flex items-center justify-center order-1 lg:order-2 group">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,_rgba(212,175,55,0.15)_0%,_transparent_60%)]"></div>

        <div class="relative w-64 md:w-80 aspect-square [perspective:2000px] [transform-style:preserve-3d]">
          <div class="absolute z-20 w-48 md:w-56 aspect-[3/4] bg-[#FDFBF7] text-charcoal p-6 rounded-xl shadow-[0_20px_50px_rgba(0,0,0,0.6)] flex flex-col justify-between pointer-events-none animate-[floatCard_6s_infinite_ease-in-out]">
            <div class="flex justify-between items-center">
              <span class="font-serif text-[10px] font-black tracking-widest text-charcoal/40 uppercase">A Gift For You</span>
              <span class="text-gold">✨</span>
            </div>
            <div class="text-center space-y-4">
              <p class="font-serif italic text-xl leading-relaxed">"Some moments<br>are meant to<br>last forever."</p>
              <div class="w-8 h-px bg-gold mx-auto"></div>
            </div>
            <div class="text-center">
              <span class="font-black tracking-widest text-xs uppercase text-charcoal/80">LumiBrace</span>
            </div>
            <div class="absolute inset-0 bg-gradient-to-tr from-black/5 via-transparent to-white/40 rounded-xl pointer-events-none"></div>
          </div>

          <div class="absolute z-10 w-56 md:w-64 aspect-square [transform-style:preserve-3d] animate-[floatBox_7s_infinite_ease-in-out_0.5s]">
            <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-[110%] h-6 bg-black/80 blur-xl rounded-full translate-z-[-40px]"></div>
            
            <div class="absolute inset-0 bg-[#121212] rounded-2xl border border-white/5 shadow-[inset_0_0_40px_rgba(0,0,0,0.8)] translate-z-[-20px]">
              <div class="absolute inset-4 bg-black/50 rounded-lg flex items-center justify-center">
                <div class="w-16 h-16 rounded-full bg-[#070707] blur-[2px] shadow-[inset_0_0_10px_black]"></div>
              </div>
            </div>

            <div class="absolute inset-0 bg-[#181818] rounded-2xl border border-white/10 shadow-[0_15px_40px_rgba(0,0,0,0.7)] translate-3d-[8px,-16px,12px] -rotate-3 flex flex-col items-center justify-center pointer-events-none">
              <div class="absolute top-0 bottom-0 left-1/2 -translate-x-1/2 w-6 bg-gradient-to-r from-[#aa7c11] via-gold to-[#aa7c11] shadow-[0_2px_8px_rgba(0,0,0,0.3)] z-10"></div>
              <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 h-6 bg-gradient-to-b from-[#aa7c11] via-gold to-[#aa7c11] shadow-[0_2px_8px_rgba(0,0,0,0.3)] z-10"></div>
              
              <div class="relative z-20 w-20 h-20 bg-[#111] border border-gold/40 rounded-lg flex flex-col items-center justify-center shadow-[0_6px_15px_rgba(0,0,0,0.6)] -translate-y-0.5">
                <span class="text-gold text-lg mb-1">✨</span>
                <span class="text-gold font-black text-[10px] tracking-widest">LUMI<span class="font-light opacity-80">BRACE</span></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
@keyframes floatCard {
  0%, 100% { transform: translate3d(50px, -40px, 60px) rotateZ(12deg) rotateY(10deg); }
  50% { transform: translate3d(60px, -20px, 65px) rotateZ(14deg) rotateY(8deg); }
}
@keyframes floatBox {
  0%, 100% { transform: translate3d(-30px, 20px, 0) rotateX(22deg) rotateY(-12deg); }
  50% { transform: translate3d(-30px, 5px, 0) rotateX(25deg) rotateY(-10deg); }
}
</style>

{% schema %}
{
  "name": "Gift Experience",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "יותר מסתם תכשיט" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "המתנה שתגרום להם\nלהתרגש באמת." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "אנחנו לא מוכרים צמידים, אנחנו מוכרים דרך לשמור את האנשים שאתם הכי אוהבים קרוב אליכם. בכל פעם שהם יסתכלו לתוך הקריסטל, הם יזכרו בכם ויחייכו." }
  ],
  "blocks": [
    {
      "type": "occasion",
      "name": "Occasion Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Occasion Title" },
        { "type": "textarea", "id": "description", "label": "Occasion Description" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Gift Experience",
      "blocks": [
        { "type": "occasion", "settings": { "title": "יום האהבה", "description": "הדרך הכי רומנטית להגיד 'אני אוהב אותך' עם רגע קסום ששניכם חולקים." } },
        { "type": "occasion", "settings": { "title": "יום הולדת", "description": "מתנה אישית ומקורית שתשאיר אותם ללא מילים ותלווה אותם בכל יום מחדש." } },
        { "type": "occasion", "settings": { "title": "יום נישואין", "description": "הנציחו את הרגע הגדול והמשמעותי ביותר שלכם בתכשיט יוקרתי שנשמר לנצח." } }
      ]
    }
  ]
}
{% endschema %}
