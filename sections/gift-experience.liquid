{% comment %}
  LumiBrace Premium Gift Experience Section — Interactive 3D floating box & card, with custom lists
{% endcomment %}

<section class="section" style="background-color: #050505; position: relative; overflow: hidden;">
  {% comment %} Decorative Background glow {% endcomment %}
  <div style="position: absolute; top: 0; right: 0; width: 350px; height: 350px; background: rgba(212,175,55,0.06); border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 1;"></div>
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="product__grid" style="align-items: center; gap: 64px;">
      
      {% comment %} Left side: Marketing text and occasions {% endcomment %}
      <div style="display: flex; flex-direction: column; gap: 24px;">
        <span class="gold" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.3em; font-weight: 900; display: block;">
          {{ section.settings.badge }}
        </span>
        <h2 style="font-size: clamp(32px, 6vw, 52px); font-weight: 900; line-height: 1.2;">
          {{ section.settings.heading | newline_to_br }}
        </h2>
        <p class="muted" style="font-size: 17px; line-height: 1.7;">
          {{ section.settings.description }}
        </p>

        <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px;">
          {%- for block in section.blocks -%}
            <div class="card" style="display: flex; gap: 20px; align-items: flex-start; padding: 20px; border-radius: 20px; transition: var(--transition);" {{ block.shopify_attributes }}>
              <div class="step-card__icon-box" style="width: 44px; height: 44px; border-radius: 12px; font-size: 20px; margin-bottom: 0; display: flex; align-items: center; justify-content: center; shrink-0;">
                {%- if forloop.index == 1 -%}❤️{%- elsif forloop.index == 2 -%}🎂{%- else -%}💍{%- endif -%}
              </div>
              <div style="text-align: right;">
                <h4 style="font-size: 17px; font-weight: 700; margin-bottom: 2px;">{{ block.settings.title }}</h4>
                <p class="muted" style="font-size: 13px; line-height: 1.4;">{{ block.settings.description }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      {% comment %} Right side: Immersive Floating 3D Gift Box & Greeting Card {% endcomment %}
      <div style="position: relative; width: 100%; aspect-ratio: 4/5; border-radius: 40px; overflow: hidden; background: #0A0A0A; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center;">
        
        {% comment %} Radial Background lighting {% endcomment %}
        <div style="position: absolute; inset: 0; background: radial-gradient(circle at 50% 50%, rgba(212,175,55,0.06) 0%, transparent 65%); pointer-events: none;"></div>

        <div class="pkg-3d-scene" style="position: relative; width: 320px; height: 320px; perspective: 2000px; transform-style: preserve-3d;">
          
          {% comment %} Floating Greeting Card {% endcomment %}
          <div class="pkg-3d-card" style="position: absolute; z-index: 20; width: 200px; aspect-ratio: 3/4; background: #FDFBF7; color: #1a1a1a; padding: 24px; rounded: 4px; box-shadow: 0 20px 50px rgba(0,0,0,0.6); display: flex; flex-direction: column; justify-content: space-between; transform: translate3d(50px, -40px, 60px) rotateZ(12deg) rotateY(10deg); border-radius: 6px; pointer-events: none; animation: floatCard 6s infinite ease-in-out;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="font-family: 'Playfair Display', serif; font-size: 9px; font-weight: 900; letter-spacing: 0.15em; color: #888; text-transform: uppercase;">A Gift For You</span>
              <span style="color: var(--gold); font-size: 14px;">✨</span>
            </div>
            <div style="text-align: center; display: flex; flex-direction: column; gap: 8px;">
              <p style="font-family: 'Playfair Display', serif; font-style: italic; font-size: 18px; color: #333; line-height: 1.3;">"Some moments <br>are meant to <br>last forever."</p>
              <div style="width: 32px; height: 1px; background: var(--gold); margin: 0 auto;"></div>
            </div>
            <div style="text-align: center;">
              <span style="font-weight: 900; letter-spacing: 0.15em; font-size: 11px; text-transform: uppercase; color: #111;">LumiBrace</span>
            </div>
            {% comment %} Lighting texture {% endcomment %}
            <div style="position: absolute; inset: 0; background: linear-gradient(to top right, rgba(0,0,0,0.03), transparent, rgba(255,255,255,0.4)); border-radius: 6px; pointer-events: none;"></div>
          </div>

          {% comment %} Floating 3D Gift Box {% endcomment %}
          <div class="pkg-3d-box" style="position: absolute; z-index: 10; width: 240px; aspect-ratio: 1; transform: translate3d(-30px, 20px, 0) rotateX(22deg) rotateY(-12deg); transform-style: preserve-3d; animation: floatBox 7s infinite ease-in-out 0.5s;">
            {% comment %} Shadow {% endcomment %}
            <div style="position: absolute; bottom: -20px; left: 50%; width: 110%; height: 24px; background: rgba(0,0,0,0.8); filter: blur(16px); border-radius: 50%; transform: translateX(-50%) translateZ(-40px); pointer-events: none;"></div>

            {% comment %} Box Base {% endcomment %}
            <div style="position: absolute; inset: 0; background: #121212; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); box-shadow: inset 0 0 40px rgba(0,0,0,0.8); transform: translateZ(-20px);">
              <div style="position: absolute; inset: 16px; bg: rgba(0,0,0,0.5); border-radius: 6px; display: flex; align-items: center; justify-content: center;">
                <div style="width: 60px; height: 60px; border-radius: 50%; background: #070707; filter: blur(2px); box-shadow: inset 0 0 10px black;"></div>
              </div>
            </div>

            {% comment %} Box Lid (raised and rotated) {% endcomment %}
            <div style="position: absolute; inset: 0; background: #181818; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 15px 40px rgba(0,0,0,0.7); transform: translate3d(8px, -16px, 12px) rotateZ(-3deg); display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none;">
              {% comment %} Ribbon Vertical {% endcomment %}
              <div style="position: absolute; top: 0; bottom: 0; left: 50%; transform: translateX(-50%); width: 24px; background: linear-gradient(90deg, #aa7c11, var(--gold), #aa7c11); box-shadow: 0 2px 8px rgba(0,0,0,0.3); z-index: 1;"></div>
              {% comment %} Ribbon Horizontal {% endcomment %}
              <div style="position: absolute; left: 0; right: 0; top: 50%; transform: translateY(-50%); h: 24px; height: 24px; background: linear-gradient(180deg, #aa7c11, var(--gold), #aa7c11); box-shadow: 0 2px 8px rgba(0,0,0,0.3); z-index: 1;"></div>

              {% comment %} Center Logo Badge {% endcomment %}
              <div style="position: relative; z-index: 2; width: 72px; height: 72px; background: #111; border: 1px solid rgba(212,175,55,0.4); border-radius: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 6px 15px rgba(0,0,0,0.6); transform: translateY(-2px);">
                <span style="color: var(--gold); font-size: 14px; margin-bottom: 2px;">✨</span>
                <span style="color: var(--gold); font-weight: 900; font-size: 9px; letter-spacing: 0.1em;">LUMI<span style="font-weight:300; opacity:0.8;">BRACE</span></span>
              </div>
            </div>

          </div>

        </div>

      </div>

    </div>
  </div>
</section>

<style>
@keyframes floatCard {
  0%, 100% {
    transform: translate3d(45px, -45px, 60px) rotateZ(12deg) rotateY(10deg);
  }
  50% {
    transform: translate3d(55px, -25px, 65px) rotateZ(14deg) rotateY(8deg);
  }
}
@keyframes floatBox {
  0%, 100% {
    transform: translate3d(-30px, 20px, 0) rotateX(22deg) rotateY(-12deg);
  }
  50% {
    transform: translate3d(-30px, 5px, 0) rotateX(25deg) rotateY(-10deg);
  }
}
</style>

{% schema %}
{
  "name": "Gift Experience",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "יותר מסתם תכשיט" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "המתנה שתגרום להם\nלהתרגש באמת." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "אנחנו לא מוכרים צמידים, אנחנו מוכרים דרך לשמור את האנשים שאתם הכי אוהבים קרוב אליכם. בכל פעם שהם יסתכלו לתוך הקריסטל, הם יזכרו בכם ויחייכו." }
  ],
  "blocks": [
    {
      "type": "occasion",
      "name": "Occasion Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Occasion Title" },
        { "type": "textarea", "id": "description", "label": "Occasion Description" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Gift Experience",
      "blocks": [
        { "type": "occasion", "settings": { "title": "יום האהבה", "description": "הדרך הכי רומנטית להגיד 'אני אוהב אותך' עם רגע קסום ששניכם חולקים." } },
        { "type": "occasion", "settings": { "title": "יום הולדת", "description": "מתנה אישית ומקורית שתשאיר אותם ללא מילים ותלווה אותם בכל יום מחדש." } },
        { "type": "occasion", "settings": { "title": "יום נישואין", "description": "הנציחו את הרגע הגדול והמשמעותי ביותר שלכם בתכשיט יוקרתי שנשמר לנצח." } }
      ]
    }
  ]
}
{% endschema %}
