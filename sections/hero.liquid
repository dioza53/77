{% comment %}
  LumiBrace Premium Hero Section — customizable video/image background and metallic gradients
{% endcomment %}

<section class="relative min-h-[90vh] md:h-screen flex items-center justify-center overflow-hidden pt-20">
  <div class="absolute inset-0 z-0">
    {%- if section.settings.video_url != blank -%}
      <video autoPlay loop muted playsInline class="w-full h-full object-cover opacity-40">
        <source src="{{ section.settings.video_url }}" type="video/mp4"/>
      </video>
    {%- elsif section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" class="w-full h-full object-cover opacity-40" />
    {%- endif -%}
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal/20 via-charcoal/40 to-charcoal"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10 text-center py-12">
    <div class="animate-fade-in-up">
      <h1 class="text-4xl md:text-8xl font-bold mb-6 tracking-tighter leading-tight">{{ section.settings.heading }}</h1>
      <p class="text-base md:text-xl text-pearl/80 mb-10 max-w-2xl mx-auto font-light leading-relaxed">{{ section.settings.subheading }}</p>
      <div class="flex flex-col md:flex-row items-center justify-center gap-4">
        <a href="{{ section.settings.cta_url }}" class="w-full md:w-auto px-10 py-4 bg-gold text-charcoal font-bold rounded-full text-lg hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-gold/20 focus-visible:ring-2 focus-visible:ring-white outline-none block text-center">
          {{ section.settings.cta_label }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "הזיכרון שלך,\nתמיד איתך." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "צמיד הקרנה יוקרתי המכיל את הרגעים היפים ביותר שלכם. איכות ללא פשרות, עיצוב נצחי ורגש שעובר בכל מבט." },
    { "type": "text", "id": "cta_label", "label": "CTA Label", "default": "הזמינו עכשיו" },
    { "type": "url", "id": "cta_url", "label": "CTA URL", "default": "/products/lumibrace" },
    { "type": "text", "id": "video_url", "label": "Background Video URL", "default": "https://assets.mixkit.co/videos/preview/mixkit-light-particles-floating-in-a-dark-background-10-large.mp4" },
    { "type": "image_picker", "id": "image", "label": "Fallback Image Background" }
  ],
  "presets": [ { "name": "Hero" } ]
}
{% endschema %}
