{% comment %}
  LumiBrace Premium Hero Section — customizable video/image background and metallic gradients
{% endcomment %}

<section class="relative min-h-[90vh] md:h-screen flex items-center justify-center overflow-hidden pt-20 bg-charcoal">
  <!-- Ambient floating particles and light beams -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <!-- Glowing Orbs -->
    <div class="absolute top-1/4 left-1/4 w-[300px] h-[300px] bg-gold/10 rounded-full blur-[120px] animate-pulse" style="animation-duration: 8s;"></div>
    <div class="absolute bottom-1/3 right-1/4 w-[250px] h-[250px] bg-gold/5 rounded-full blur-[100px] animate-pulse" style="animation-duration: 6s; animation-delay: 2s;"></div>
    
    <!-- Floating Light Particles -->
    <div class="absolute inset-0 opacity-30">
      <div class="absolute w-2 h-2 bg-gold/60 rounded-full blur-[1px] animate-float top-12 left-10" style="animation-delay: 0s; animation-duration: 12s;"></div>
      <div class="absolute w-3 h-3 bg-gold/40 rounded-full blur-[2px] animate-float top-1/3 left-1/4" style="animation-delay: 3s; animation-duration: 18s;"></div>
      <div class="absolute w-1.5 h-1.5 bg-gold/70 rounded-full animate-float top-2/3 left-12" style="animation-delay: 1s; animation-duration: 10s;"></div>
      <div class="absolute w-2.5 h-2.5 bg-gold/50 rounded-full blur-[1px] animate-float top-1/4 right-1/3" style="animation-delay: 5s; animation-duration: 15s;"></div>
      <div class="absolute w-2 h-2 bg-gold/60 rounded-full blur-[2px] animate-float top-1/2 right-12" style="animation-delay: 2s; animation-duration: 14s;"></div>
      <div class="absolute w-3 h-3 bg-gold/30 rounded-full blur-[3px] animate-float bottom-1/4 right-1/4" style="animation-delay: 4s; animation-duration: 20s;"></div>
    </div>

    <!-- Holographic Projection Beam Effect -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-[radial-gradient(ellipse_at_bottom,_rgba(212,175,55,0.15)_0%,_transparent_70%)] pointer-events-none"></div>

    {%- if section.settings.video_url != blank -%}
      <video autoPlay loop muted playsInline class="w-full h-full object-cover opacity-30 mix-blend-screen">
        <source src="{{ section.settings.video_url }}" type="video/mp4"/>
      </video>
    {%- elsif section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" class="w-full h-full object-cover opacity-30" />
    {%- endif -%}
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal/40 via-charcoal/70 to-charcoal"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10 text-center py-12">
    <div class="space-y-8 max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-8xl font-bold mb-6 tracking-tighter leading-tight text-pearl">
        {%- assign clean_heading = section.settings.heading | newline_to_br | replace: '<br />', '<br>' -%}
        {%- assign lines = clean_heading | split: '<br>' -%}
        {%- if lines.size > 1 -%}
          {{ lines[0] }}<br><span class="gold-text-gradient">{{ lines[1] }}</span>
        {%- else -%}
          {{ section.settings.heading | newline_to_br }}
        {%- endif -%}
      </h1>
      <p class="text-base md:text-xl text-pearl/80 mb-10 max-w-2xl mx-auto font-light leading-relaxed">{{ section.settings.subheading }}</p>
      <div class="flex flex-col md:flex-row items-center justify-center gap-4">
        <a href="#design" onclick="document.getElementById('design')?.scrollIntoView({behavior: 'smooth'}); return false;" class="w-full md:w-auto px-10 py-4 bg-gold text-charcoal font-bold rounded-full text-lg hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-gold/20 outline-none block text-center">
          {{ section.settings.cta_label }}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0% { transform: translateY(100vh) scale(0.8); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-20vh) scale(1.2); opacity: 0; }
  }
  .animate-float {
    animation-name: float;
    animation-iteration-count: infinite;
    animation-timing-function: linear;
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "הזיכרון שלך,\nתמיד איתך." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "צמיד הקרנה יוקרתי המכיל את הרגעים היפים ביותר שלכם. איכות ללא פשרות, עיצוב נצחי ורגש שעובר בכל מבט." },
    { "type": "text", "id": "cta_label", "label": "CTA Label", "default": "הזמינו עכשיו" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "text", "id": "video_url", "label": "Background Video URL", "default": "https://assets.mixkit.co/videos/preview/mixkit-light-particles-floating-in-a-dark-background-10-large.mp4" },
    { "type": "image_picker", "id": "image", "label": "Fallback Image Background" }
  ],
  "presets": [ { "name": "Hero" } ]
}
{% endschema %}
