{% comment %}
  LumiBrace Premium How It Works Section — customizable steps with media (images/videos)
{% endcomment %}

<section id="how-it-works" class="py-24 bg-charcoal relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-[500px] bg-gold/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20 space-y-4">
      <span class="px-4 py-1.5 rounded-full bg-gold/10 text-gold text-xs font-bold uppercase tracking-widest inline-block mb-4 border border-gold/20 shadow-[0_0_15px_rgba(212,175,55,0.2)]">{{ section.settings.badge }}</span>
      <h2 class="text-4xl md:text-5xl font-black text-pearl tracking-tight">{{ section.settings.heading }}</h2>
      <p class="text-pearl/60 text-lg max-w-2xl mx-auto">{{ section.settings.subheading }}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 md:gap-12 max-w-6xl mx-auto relative">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-0.5 bg-gradient-to-r from-transparent via-gold/20 to-transparent hidden md:block"></div>
      
      {%- for block in section.blocks -%}
        <div class="relative bg-charcoal/80 backdrop-blur-xl border border-pearl/10 rounded-[2.5rem] p-8 text-center hover:border-gold/30 hover:shadow-[0_0_30px_rgba(212,175,55,0.15)] transition-all duration-500 group" {{ block.shopify_attributes }}>
          <div class="absolute -top-6 left-1/2 -translate-x-1/2 w-12 h-12 rounded-2xl bg-gradient-to-br from-gold to-yellow-600 text-charcoal font-black text-xl flex items-center justify-center shadow-lg shadow-gold/20 rotate-3 group-hover:rotate-6 transition-transform">
            {{ forloop.index }}
          </div>
          
          <div class="w-20 h-20 mx-auto rounded-full bg-gold/10 border border-gold/20 flex items-center justify-center text-gold mb-8 mt-4 group-hover:scale-110 transition-transform duration-500">
            {%- if forloop.index == 1 -%}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-camera w-8 h-8"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path><circle cx="12" cy="13" r="3"></circle></svg>
            {%- elsif forloop.index == 2 -%}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gem w-8 h-8"><path d="M6 3h12l4 6-10 13L2 9Z"></path><path d="M11 3v18"></path><path d="m2 9 10 13"></path><path d="M22 9 12 22"></path></svg>
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-flashlight w-8 h-8"><path d="M18 6c0 2-2 2-2 4v10a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2V10c0-2-2-2-2-4V2h12z"></path><line x1="6" x2="18" y1="6" y2="6"></line><line x1="12" x2="12" y1="12" y2="12"></line></svg>
            {%- endif -%}
          </div>

          <h3 class="text-xl font-black text-pearl mb-4">{{ block.settings.title }}</h3>
          <p class="text-pearl/60 text-sm leading-relaxed mb-6">{{ block.settings.description }}</p>

          {%- if block.settings.video_url != blank or block.settings.image != blank -%}
            <div class="mt-8 rounded-2xl overflow-hidden aspect-square relative group-hover:shadow-2xl transition-shadow border border-pearl/10">
              {%- if block.settings.video_url != blank -%}
                <video src="{{ block.settings.video_url }}" autoplay loop muted playsinline class="w-full h-full object-cover"></video>
              {%- elsif block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title }}" loading="lazy" class="w-full h-full object-cover">
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "התהליך שלנו" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "איך הקסם קורה?" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "3 שלבים פשוטים בדרך לצמיד הכי אישי ומרגש שיהיה לכם אי פעם." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "העלו תמונה" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "בוחרים את הרגע הכי מרגש שלכם ומעלים אותו ישירות לאתר. המערכת תעזור לכם למרכז את התמונה." },
        { "type": "image_picker", "id": "image", "label": "Step Image" },
        { "type": "text", "id": "video_url", "label": "Step Video URL (Optional)" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "מעלים תמונה", "description": "בוחרים את הרגע הכי מרגש שלכם ומעלים אותו ישירות לאתר. המערכת תעזור לכם למרכז את התמונה." } },
        { "type": "step", "settings": { "title": "אנחנו מייצרים", "description": "האמנים שלנו חורטים את התמונה בטכנולוגיית ננו-לייזר בתוך קריסטל HD איכותי, המשובץ בעבודת יד בצמיד." } },
        { "type": "step", "settings": { "title": "אתם מקרינים", "description": "הצמידו את העין או השתמשו בפנס הטלפון כדי להקרין את הזיכרון שלכם בגדול. רגע קסום שמלווה אתכם." } }
      ]
    }
  ]
}
{% endschema %}
