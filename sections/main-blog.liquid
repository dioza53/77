<section class="section container">
  <h1>{{ blog.title }}</h1>
  <div class="testimonials">
    {%- for article in blog.articles -%}
      <a href="{{ article.url }}" class="card">
        <h3>{{ article.title }}</h3>
        <p class="muted">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
      </a>
    {%- endfor -%}
  </div>
</section>
{% schema %}{ "name": "Blog" }{% endschema %}
