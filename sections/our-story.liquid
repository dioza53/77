{% comment %}
  LumiBrace Our Story Section — premium brand description & craftsmanship icons
{% endcomment %}

<section id="our-story" class="py-24 bg-charcoal relative overflow-hidden">
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[300px] h-[300px] bg-gold/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-20 space-y-4">
      <span class="px-4 py-1.5 rounded-full bg-gold/10 text-gold text-xs font-bold uppercase tracking-widest inline-flex items-center gap-2 mb-4 border border-gold/20 shadow-[0_0_15px_rgba(212,175,55,0.2)]">
        📖 {{ section.settings.badge }}
      </span>
      <h2 class="text-4xl md:text-5xl font-black text-pearl tracking-tight leading-tight">{{ section.settings.heading | newline_to_br }}</h2>
      <p class="text-pearl/60 text-lg leading-relaxed max-w-2xl mx-auto">{{ section.settings.description }}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-center max-w-6xl mx-auto">
      
      <div class="space-y-8 text-right">
        <h3 class="text-3xl font-black text-pearl">{{ section.settings.col1_heading }}</h3>
        <div class="text-pearl/60 text-lg leading-relaxed space-y-6">
          <p>{{ section.settings.col1_text1 }}</p>
          <p>{{ section.settings.col1_text2 }}</p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6 pt-4">
          <div class="bg-pearl/5 border border-pearl/10 p-6 rounded-2xl text-right">
            <span class="text-2xl mb-2 block">❤️</span>
            <span class="block text-pearl font-bold text-lg mb-1">מיוצר באהבה</span>
            <span class="text-pearl/50 text-xs">כל הזמנה מטופלת באופן אישי ומבוקרת ידנית.</span>
          </div>
          <div class="bg-pearl/5 border border-pearl/10 p-6 rounded-2xl text-right">
            <span class="text-2xl mb-2 block">✨</span>
            <span class="block text-pearl font-bold text-lg mb-1">חזון המותג</span>
            <span class="text-pearl/50 text-xs">לחבר בין אנשים דרך רגעים של אור וזיכרון.</span>
          </div>
        </div>
      </div>

      <div class="relative bg-black/40 backdrop-blur-md border border-gold/20 p-8 md:p-12 rounded-[2.5rem] overflow-hidden text-right group hover:border-gold/40 transition-colors">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(212,175,55,0.15)_0%,_transparent_70%)] pointer-events-none group-hover:opacity-100 opacity-50 transition-opacity duration-500"></div>
        
        <div class="relative z-10 space-y-10">
          <h3 class="text-3xl font-black text-pearl leading-tight">
            אמנות הדיוק <br><span class="text-gold">והאיכות ללא פשרות</span>
          </h3>
          <p class="text-pearl/60 text-base leading-relaxed">
            אנחנו לא מתפשרים על פחות מהטוב ביותר. הצמידים שלנו עשויים מפלדת אל-חלד 316L בדרגה רפואית, המבטיחה עמידות מלאה במים, היפואלרגניות וברק שאינו דוהה.
          </p>

          <ul class="space-y-6">
            <li class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center shrink-0 border border-gold/20 group-hover:scale-110 transition-transform">
                <span class="text-xl">💎</span>
              </div>
              <div class="pt-1">
                <h4 class="text-pearl font-bold text-base mb-1">קריסטל HD אופטי</h4>
                <p class="text-pearl/50 text-sm">עדשה מלוטשת המעניקה חדות מקסימלית להקרנה.</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center shrink-0 border border-gold/20 group-hover:scale-110 transition-transform">
                <span class="text-xl">🛡️</span>
              </div>
              <div class="pt-1">
                <h4 class="text-pearl font-bold text-base mb-1">עמידות מלאה במים</h4>
                <p class="text-pearl/50 text-sm">אינו משחיר לעולם - עמיד במקלחות, ים וספורט.</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center shrink-0 border border-gold/20 group-hover:scale-110 transition-transform">
                <span class="text-xl">👥</span>
              </div>
              <div class="pt-1">
                <h4 class="text-pearl font-bold text-base mb-1">קהילה של אלפים</h4>
                <p class="text-pearl/50 text-sm">מעל 10,000 לקוחות מרוצים ששומרים את הזיכרון קרוב אליהם.</p>
              </div>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Our Story",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "הסיפור שלנו" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "יותר מתכשיט,\nזה הלב שלכם." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "LumiBrace נולדה מתוך רצון פשוט: להפוך את הזיכרונות הכי יקרים שלנו למשהו שאפשר לענוד, להרגיש ולראות בכל רגע." },
    { "type": "text", "id": "col1_heading", "label": "Inspiration Heading", "default": "ההשראה שמאחורי LumiBrace" },
    { "type": "textarea", "id": "col1_text1", "label": "Inspiration Paragraph 1", "default": "הכל התחיל כשחיפשנו דרך להנציח רגע מיוחד. רצינו משהו שהוא לא רק תמונה בטלפון או בתוך מסגרת על הקיר. רצינו משהו אישי, אינטימי, כזה שנמצא תמיד איתנו." },
    { "type": "textarea", "id": "col1_text2", "label": "Inspiration Paragraph 2", "default": "השילוב בין עולם הצורפות המסורתי לבין טכנולוגיית ננו-אופטיקה מתקדמת אפשר לנו ליצור את הבלתי יאומן: קריסטל זעיר שמכיל בתוכו עולם שלם של רגש." }
  ],
  "presets": [ { "name": "Our Story" } ]
}
{% endschema %}
