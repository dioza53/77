{% comment %}
  LumiBrace Premium Product Configurator — RTL & Mobile optimized
  Natively integrates image uploads (via Shopify properties) and a fallback for WhatsApp submissions.
{% endcomment %}

{%- assign product = product | default: all_products[section.settings.product] | default: collections.all.products.first -%}

{%- if product != blank -%}
{%- assign first_variant = product.selected_or_first_available_variant -%}

<section id="design" class="py-24 bg-charcoal relative overflow-hidden" data-product>
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-[1.2fr_1fr] gap-16 items-start">
      
      {% comment %} Left side: Gallery + Product Info (matching Lovable layout) {% endcomment %}
      <div class="space-y-8 lg:sticky lg:top-32">
      <div class="relative group">
        <div class="space-y-6">
          <div style="display: flex; gap: 4px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 4px; width: fit-content; margin: 0 auto 24px auto;" role="tablist" aria-label="מצבי תצוגה">
            <button type="button" style="padding: 8px 24px; border-radius: 12px; font-size: 14px; font-weight: bold; transition: all 0.3s; background: var(--gold); color: #121212; box-shadow: 0 4px 12px rgba(212,175,55,0.2);" class="gallery-toggle__btn is-active" data-gallery-tab="product" role="tab" aria-selected="true">
              הצמיד
            </button>
            <button type="button" style="padding: 8px 24px; border-radius: 12px; font-size: 14px; font-weight: bold; transition: all 0.3s; background: transparent; color: rgba(255,255,255,0.4);" class="gallery-toggle__btn" data-gallery-tab="projection" role="tab" aria-selected="false">
              ההקרנה
            </button>
          </div>

          <div class="relative aspect-square rounded-[2.5rem] overflow-hidden bg-black/20 border border-pearl/5 group shadow-2xl touch-pan-y product__media-wrapper">
            <div class="absolute top-4 right-4 z-20 px-3 py-1.5 bg-charcoal/70 backdrop-blur-md border border-pearl/10 rounded-full text-[11px] font-bold text-pearl/90 tracking-wider" data-gallery-counter>1 / {{ product.images.size | default: 1 }}</div>
            <div class="absolute inset-x-3 top-1/2 -translate-y-1/2 flex justify-between items-center z-20 pointer-events-none">
              <button type="button" aria-label="תמונה קודמת" class="pointer-events-auto w-10 h-10 rounded-full bg-charcoal/60 backdrop-blur-md flex items-center justify-center text-pearl hover:bg-gold hover:text-charcoal transition-colors focus-visible:ring-2 focus-visible:ring-gold outline-none" data-gallery-prev>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right w-5 h-5"><path d="m9 18 6-6-6-6"></path></svg>
              </button>
              <button type="button" aria-label="תמונה הבאה" class="pointer-events-auto w-10 h-10 rounded-full bg-charcoal/60 backdrop-blur-md flex items-center justify-center text-pearl hover:bg-gold hover:text-charcoal transition-colors focus-visible:ring-2 focus-visible:ring-gold outline-none" data-gallery-next>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left w-5 h-5"><path d="m15 18-6-6 6-6"></path></svg>
              </button>
            </div>
        {% comment %} Main product image gallery {% endcomment %}
        <div class="product__gallery" data-gallery-content="product">
          {%- if product.featured_image -%}
            <img id="product-image" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" class="w-full h-full object-cover" loading="eager" fetchpriority="high">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg w-full h-full object-cover' }}
          {%- endif -%}
        </div>

        {% comment %} Simulated circle projection preview {% endcomment %}
        <div class="product__projection hidden" data-gallery-content="projection">
          <div class="projection-box">
            <div class="projection-light-beam"></div>
            <div class="projection-cone"></div>
            <div class="projection-circle">
              <div class="projection-no-image" data-projection-placeholder>
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>
                </svg>
                <p>התמונה שלכם תוקרן כאן</p>
              </div>
              <img src="" class="projection-img hidden" data-projection-preview alt="תצוגת הקרנה">
              <div class="projection-shimmer"></div>
            </div>
            <div class="projection-badge">תצוגה מקדימה של ההקרנה</div>
          </div>
            </div>
        </div>
      </div></div>
      
      {% comment %} Thumbnails {% endcomment %}
      <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-top: 16px;" data-gallery-thumbnails>
        {%- for image in product.images -%}
          <button type="button" style="aspect-ratio: 1 / 1; border-radius: 12px; overflow: hidden; border: 2px solid {% if forloop.first %}var(--gold){% else %}rgba(255,255,255,0.1){% endif %}; transition: all 0.3s; position: relative; padding: 0; background: transparent; cursor: pointer;" class="thumb-btn {% if forloop.first %}is-active{% endif %}" data-thumb-index="{{ forloop.index0 }}" data-image-url="{{ image | image_url: width: 1200 }}">
            <img src="{{ image | image_url: width: 150 }}" alt="תצוגה מקדימה {{ forloop.index }}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; opacity: {% if forloop.first %}1{% else %}0.6{% endif %}; transition: opacity 0.3s;">
          </button>
        {%- endfor -%}
      </div>

      {% comment %} Share button + Stars/Reviews row {% endcomment %}
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
        <div style="display: flex; align-items: center; gap: 8px;">
          <div style="display: flex; color: var(--gold);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
          </div>
          <span style="font-size: 14px; color: rgba(255,255,255,0.6);">(4.9/5 מתוך 1,240 ביקורות)</span>
        </div>
        <button style="padding: 12px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 50%; color: rgba(255,255,255,0.6); transition: all 0.3s; display: flex; align-items: center; justify-content: center; cursor: pointer;" title="שתפו את המוצר">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line></svg>
        </button>
      </div>

      {% comment %} Product Name + Description {% endcomment %}
      <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px;">
        <h2 style="font-size: 32px; font-weight: 900; letter-spacing: -0.05em; line-height: 1.1; margin: 0; font-family: Heebo, sans-serif;">{{ product.title | default: 'LumiBrace Signature' }}<span style="display: block; font-size: 20px; font-weight: bold; color: rgba(255,255,255,0.4); margin-top: 8px; letter-spacing: normal;">צמיד הזיכרונות המקורי עם הקרנת תמונה אישית</span></h2>
      </div>

      {% comment %} Price + Discount {% endcomment %}
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px;">
        <span style="font-size: 48px; font-weight: 900; color: var(--gold); text-shadow: 0 0 15px rgba(212,175,55,0.3); line-height: 1;" data-price>₪{{ first_variant.price | divided_by: 100 }}</span>
        {%- if first_variant.compare_at_price > first_variant.price -%}
          <div style="display: flex; flex-direction: column; gap: 4px;">
            <span style="font-size: 20px; color: rgba(255,255,255,0.4); text-decoration: line-through; text-decoration-color: rgba(212,175,55,0.5); line-height: 1;" data-compare-price>₪{{ first_variant.compare_at_price | divided_by: 100 }}</span>
            <span style="padding: 4px 12px; background: rgba(212,175,55,0.2); color: var(--gold); font-size: 10px; font-weight: bold; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.05em; width: max-content;" data-discount-badge>50% הנחה</span>
          </div>
        {%- endif -%}
      </div>

      {% comment %} Product Description - Hidden by default as per Lovable design {% endcomment %}
      {%- if false and product.description != blank -%}
        <div class="product__desc muted mt-4" style="color: rgba(255,255,255,0.6); font-size: 15px; line-height: 1.6; font-family: Heebo, sans-serif;">{{ product.description }}</div>
      {%- endif -%}

      </div>

    {% comment %} Right side: Product configuration details and forms {% endcomment %}
    <div class="space-y-10" style="font-family: Heebo, sans-serif;">

      <form action="/cart/add" method="post" enctype="multipart/form-data" class="configurator-form" data-product-form>
        <input type="hidden" name="id" value="{{ first_variant.id }}" data-variant-id>
        <input type="hidden" name="quantity" value="1">

        <div class="space-y-6">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold flex items-center gap-2" style="color: #fff; margin: 0 0 12px 0;">
              <span style="font-weight: 900; background: var(--gold); color: #121212; display: inline-flex; width: 24px; height: 24px; border-radius: 50%; align-items: center; justify-content: center; margin-left: 8px;">1</span>עצבו את הצמיד שלכם
            </h3>
          </div>

        {% comment %} Custom interactive Color options {% endcomment %}
        {%- for option in product.options_with_values -%}
          {%- unless option.name contains 'חבילה' or option.name contains 'מארז' or option.name contains 'Bundle' or option.name contains 'כמות' -%}
            <div class="space-y-3" data-option-group-position="{{ option.position }}" style="margin-bottom: 24px;">
              <p style="font-size: 14px; font-weight: bold; color: rgba(255,255,255,0.6); margin-bottom: 12px;">{% if option.name contains 'צבע' or option.name contains 'Color' %}בחרו צבע{% else %}{{ option.name }}{% endif %}:</p>
              <div style="display: flex; gap: 16px;">
                {%- for value in option.values -%}
                  {%- unless value contains 'מעורב' -%}
                  {%- assign input_id = 'opt-' | append: option.position | append: '-' | append: forloop.index -%}
                  <label class="option-pill {% if value == option.selected_value %}is-active{% endif %}" for="{{ input_id }}" style="flex: 1; padding: 24px 16px; border-radius: 24px; border: 2px solid {% if value == option.selected_value %}var(--gold){% else %}rgba(255,255,255,0.05){% endif %}; background: {% if value == option.selected_value %}rgba(212,175,55,0.05){% else %}rgba(255,255,255,0.02){% endif %}; cursor: pointer; transition: all 0.3s; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; text-align: center;">
                    <input
                      type="radio"
                      id="{{ input_id }}"
                      name="options[{{ option.name | escape }}]"
                      value="{{ value | escape }}"
                      class="sr-only"
                      data-option-input
                      data-option-position="{{ option.position }}"
                      {% if value == option.selected_value %}checked{% endif %}
                    >
                    {%- if option.name contains 'צבע' or option.name contains 'Color' -%}
                      <div style="width: 48px; height: 48px; border-radius: 50%; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); background-color:{% if value contains 'כסף' or value contains 'Silver' %}#C0C0C0{% elsif value contains 'זהב' or value contains 'Gold' %}#D4AF37{% else %}#1a1a1a{% endif %};"></div>
                    {%- endif -%}
                    <span style="font-size: 14px; font-weight: bold; color: {% if value == option.selected_value %}var(--gold){% else %}#ffffff{% endif %};">{{ value }}</span>
                  </label>
                  {%- endunless -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endunless -%}
        {%- endfor -%}

        <input type="hidden" name="properties[אופן שליחת התמונה]" value="שליחה בוואטסאפ לאחר הרכישה">
        
        <div class="space-y-3" style="margin-top: 32px; margin-bottom: 24px;">
          <p style="font-size: 14px; font-weight: bold; color: rgba(255,255,255,0.6); margin-bottom: 12px;">התמונה שלכם:</p>
          <div style="position: relative; border-radius: 24px; border: 1px solid rgba(212,175,55,0.3); background: linear-gradient(135deg, rgba(212,175,55,0.1) 0%, rgba(255,255,255,0.03) 100%); padding: 24px; text-align: right; overflow: hidden;">
            <div style="position: absolute; top: -40px; left: -40px; width: 160px; height: 160px; background: rgba(212,175,55,0.1); border-radius: 50%; filter: blur(40px); pointer-events: none;"></div>
            <div style="position: relative; display: flex; align-items: flex-start; gap: 16px;">
              <div style="flex-shrink: 0; width: 48px; height: 48px; border-radius: 16px; background: rgba(212,175,55,0.15); border: 1px solid rgba(212,175,55,0.3); display: flex; align-items: center; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles w-6 h-6 text-gold" style="color: var(--gold);" aria-hidden="true"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path><path d="M20 2v4"></path><path d="M22 4h-4"></path><circle cx="4" cy="20" r="2"></circle></svg>
              </div>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                <p style="font-size: 18px; font-weight: 900; color: #ffffff; margin: 0;">ליווי אישי לבחירת התמונה</p>
                <p style="font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.6; margin: 0;">מיד לאחר ההזמנה ניצור איתכם קשר אישי בוואטסאפ או במייל, נעבור איתכם על התמונות שלכם ונבחר יחד את התמונה המושלמת — זו שתיראה הכי יפה בהקרנה על הצמיד.</p>
                <ul style="list-style: none; padding: 0; margin: 8px 0 0 0; display: flex; flex-direction: column; gap: 8px;">
                  <li style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.85);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold); flex-shrink: 0;"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>יחס אישי — לא טופס אוטומטי</span>
                  </li>
                  <li style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.85);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold); flex-shrink: 0;"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>בדיקת איכות התמונה לפני ההדפסה</span>
                  </li>
                  <li style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.85);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold); flex-shrink: 0;"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>שינויים והתאמות חינם עד שתהיו מרוצים</span>
                  </li>
                </ul>
                <p style="font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 8px; line-height: 1.4;">אין מה להעלות עכשיו — פשוט סיימו את ההזמנה וניצור איתכם קשר תוך 24 שעות.</p>
              </div>
            </div>
          </div>
        </div>

      {% comment %} Sizing Guide & Sizing Tips Accordions {% endcomment %}
      <div style="margin-top: 24px; display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px;">
        <div style="border: 1px solid rgba(212,175,55,0.2); border-radius: 20px; overflow: hidden; background: rgba(212,175,55,0.03);">
          <details class="group" style="list-style: none;">
            <summary style="width: 100%; padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; user-select: none; outline: none; list-style: none;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(212,175,55,0.15); display: flex; align-items: center; justify-content: center; color: var(--gold);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lightbulb w-4 h-4"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"></path><path d="M9 18h6"></path><path d="M10 22h4"></path></svg>
                </div>
                <span style="font-weight: bold; font-size: 14px; color: #ffffff;">טיפים לעיצוב מושלם</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down text-gold" style="color: var(--gold);"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div style="padding: 0 20px 20px 20px; font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.6;">
              <ul style="list-style: disc; list-style-position: inside; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px;">
                <li>בחרו תמונה חדה וברורה.</li>
                <li>תאורה טובה עושה את ההבדל.</li>
                <li>מרכזו את נושא התמונה.</li>
              </ul>
            </div>
          </details>
        </div>
        <div style="border: 1px solid rgba(212,175,55,0.2); border-radius: 20px; overflow: hidden; background: rgba(212,175,55,0.03);">
          <details class="group" style="list-style: none;">
            <summary style="width: 100%; padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; user-select: none; outline: none; list-style: none;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(212,175,55,0.15); display: flex; align-items: center; justify-content: center; color: var(--gold);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ruler w-4 h-4"><path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"></path><path d="m14.5 12.5 2-2"></path><path d="m11.5 9.5 2-2"></path><path d="m8.5 6.5 2-2"></path><path d="m17.5 15.5 2-2"></path></svg>
                </div>
                <span style="font-weight: bold; font-size: 14px; color: #ffffff;">איך עובדות המידות?</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down text-gold" style="color: var(--gold);"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div style="padding: 0 20px 20px 20px; font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.6;">
              <p style="margin: 0 0 8px 0;"><strong>מידה אחת שמתאימה לכולם:</strong> צמידי LumiBrace מעוצבים בשיטה מתכווננת המתאימה לכולם.</p>
              <p style="margin: 0 0 8px 0;"><strong>אורך הצמיד:</strong> 16 ס"מ בסיס + 5 ס"מ הארכה (16-21 ס"מ).</p>
              <p style="margin: 0;"><strong>מתנה מושלמת:</strong> אין צורך לנחש מידות!</p>
            </div>
          </details>
        </div>
      </div>
      </div> <!-- End Step 1 div -->

      {% comment %} Custom interactive Bundle options (Step 2) - rendered after accordions {% endcomment %}
      {%- for option in product.options_with_values -%}
        {%- if option.name contains 'חבילה' or option.name contains 'מארז' or option.name contains 'Bundle' or option.name contains 'כמות' -%}
          <div class="space-y-4" data-option-group-position="{{ option.position }}" style="margin-top: 32px; margin-bottom: 24px;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <h3 style="font-size: 18px; font-weight: bold; color: #fff; margin: 0 0 12px 0; display: flex; align-items: center; gap: 8px;">
                <span style="font-weight: 900; background: var(--gold); color: #121212; display: inline-flex; width: 24px; height: 24px; border-radius: 50%; align-items: center; justify-content: center; font-size: 12px;">2</span>בחרו את המבצע שלכם
              </h3>
            </div>
            <div style="display: grid; gap: 16px;" role="radiogroup" aria-label="בחירת מבצע">
              {%- for value in option.values -%}
                {%- assign input_id = 'opt-' | append: option.position | append: '-' | append: forloop.index -%}
                {%- assign is_pair = false -%}
                {%- if value contains 'זוג' or value contains 'Pair' -%}
                  {%- assign is_pair = true -%}
                {%- endif -%}
                <label class="option-pill bundle-option {% if value == option.selected_value %}is-active{% endif %}" for="{{ input_id }}" style="position: relative; padding: 24px; border-radius: 24px; border: 2px solid {% if value == option.selected_value %}var(--gold){% else %}rgba(255,255,255,0.05){% endif %}; background: {% if value == option.selected_value %}rgba(212,175,55,0.05){% else %}rgba(255,255,255,0.02){% endif %}; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; justify-content: space-between; outline: none;">
                  <input type="radio" id="{{ input_id }}" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" class="sr-only" data-option-input data-option-position="{{ option.position }}" {% if value == option.selected_value %}checked{% endif %}>
                  {%- if is_pair -%}
                    <div style="position: absolute; top: 0; left: 0; background: var(--gold); color: #121212; font-size: 9px; font-weight: 900; padding: 4px 12px; border-bottom-right-radius: 12px; text-transform: uppercase;">הכי פופולארי</div>
                  {%- endif -%}
                  <div style="display: flex; align-items: center; gap: 16px;">
                    <div class="bundle-radio-circle" style="width: 24px; height: 24px; border-radius: 50%; border: 2px solid {% if value == option.selected_value %}var(--gold){% else %}rgba(255,255,255,0.2){% endif %}; flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all 0.3s;">
                      <div class="bundle-radio-inner {% unless value == option.selected_value %}hidden{% endunless %}" style="width: 12px; height: 12px; background: var(--gold); border-radius: 50%;"></div>
                    </div>
                    <div>
                      <p class="bundle-title" style="font-weight: bold; margin: 0; font-size: 16px; color: {% if value == option.selected_value %}var(--gold){% else %}#ffffff{% endif %}; transition: color 0.3s;">{{ value }}</p>
                      <p style="font-size: 12px; color: rgba(255,255,255,0.4); margin: 4px 0 0 0;">{% if is_pair %}אחד לך, אחד למישהו שאתה אוהב{% else %}התחלה מושלמת לזיכרון אישי{% endif %}</p>
                      {%- if is_pair -%}
                      <div style="display: flex; align-items: center; gap: 6px; margin-top: 8px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: #4ade80;"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg>
                        <span style="font-size: 10px; font-weight: bold; color: #4ade80; text-transform: uppercase;">משלוח חינם</span>
                      </div>
                      {%- endif -%}
                    </div>
                  </div>
                </label>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

        </div>
        
        <div class="pt-6 space-y-8">

        {% comment %} Purchase Buttons {% endcomment %}
        <button type="submit" class="w-full py-6 bg-gold text-charcoal font-black rounded-[2rem] text-xl shadow-[0_20px_50px_rgba(212,175,55,0.3)] hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-3 group relative overflow-hidden focus-visible:ring-2 focus-visible:ring-white outline-none disabled:opacity-70 disabled:cursor-not-allowed disabled:hover:scale-100 btn-buy" data-add-to-cart>
          <div class="absolute inset-0 bg-white/20 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000 ease-in-out"></div>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles w-6 h-6"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path><path d="M20 2v4"></path><path d="M22 4h-4"></path><circle cx="4" cy="20" r="2"></circle></svg>
          <span>קנו עכשיו ב-50% הנחה</span>
        </button>

        <div class="grid grid-cols-3 gap-4">
          <div class="flex flex-col items-center text-center gap-2">
            <div class="w-10 h-10 rounded-full bg-pearl/5 flex items-center justify-center text-pearl/40">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-truck w-5 h-5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg>
            </div>
            <span class="text-[10px] font-bold text-pearl/40 uppercase tracking-widest">משלוח מהיר</span>
          </div>
          <div class="flex flex-col items-center text-center gap-2">
            <div class="w-10 h-10 rounded-full bg-pearl/5 flex items-center justify-center text-pearl/40">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check w-5 h-5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
            </div>
            <span class="text-[10px] font-bold text-pearl/40 uppercase tracking-widest">איכות פרימיום</span>
          </div>
          <div class="flex flex-col items-center text-center gap-2">
            <div class="w-10 h-10 rounded-full bg-pearl/5 flex items-center justify-center text-pearl/40">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lock w-5 h-5"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            </div>
            <span class="text-[10px] font-bold text-pearl/40 uppercase tracking-widest">תשלום מאובטח</span>
          </div>
        </div>

        <div data-form-error class="form-error-msg hidden"></div>
        </div>
      </form>
    </div>
  </div>
</section>

{% comment %} Upsell Modal (Mirrors React "Don't let memory stay alone") {% endcomment %}
<div class="upsell-modal hidden" data-upsell-modal>
  <div class="upsell-modal__backdrop" data-upsell-decline></div>
  <div class="upsell-modal__body">
    <div class="upsell-modal__header-line"></div>
    <div class="upsell-modal__sparkle-icon">✨</div>
    <h3 class="upsell-modal__title">הצעה בלעדית: <br><span>אל תתנו לזיכרון להישאר לבד</span></h3>
    <p class="upsell-modal__text">גילינו שרוב הלקוחות שלנו מעדיפים לשמור צמיד אחד לעצמם ולהעניק את הצמיד השני במתנה לאדם הכי יקר להם.</p>
    
    <div class="upsell-modal__deal">
      <div class="upsell-modal__deal-info">
        <span class="upsell-modal__deal-tag">שדרוג מומלץ לזוג צמידים</span>
        <span class="upsell-modal__deal-price">₪389 בלבד <del>₪778</del></span>
      </div>
      <span class="upsell-modal__deal-badge">חיסכון של ₪389!</span>
    </div>

    <div class="upsell-modal__ctas">
      <button type="button" class="btn btn-primary btn-block" data-upsell-accept>
        כן, שדרגו אותי לזוג מרגש ב-₪389!
      </button>
      <button type="button" class="upsell-modal__decline-btn" data-upsell-decline>
        לא תודה, אני מעדיף להמשיך עם צמיד בודד
      </button>
    </div>
  </div>
</div>
{%- else -%}
  <div class="container text-center py-20" style="padding: 100px 20px; text-align: center; background: #0d0d0d; color: #fff;">
    <h2 class="gold-grad" style="font-size: 28px; margin-bottom: 15px; font-weight: 700; font-family: Heebo, sans-serif;">LumiBrace Configurator</h2>
    <p style="color: rgba(245,245,240,0.6); max-width: 500px; margin: 0 auto; font-size: 16px; font-family: Heebo, sans-serif;">
      אנא בחר מוצר להצגה במקודד/קונפיגורטור בהגדרות המקטע (או הוסף מוצר לחנות).
    </p>
  </div>
{%- endif -%}

<script>
  window.__product = {{ product | json | default: 'null' }};
</script>
<script src="{{ 'configurator.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product configurator",
  "settings": [
    { "type": "product", "id": "product", "label": "Product to customize" }
  ],
  "presets": [
    {
      "name": "Product configurator"
    }
  ]
}
{% endschema %}
