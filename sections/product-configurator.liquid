{% comment %} Upsell Modal (Mirrors React "Don't let memory stay alone") {% endcomment %}
<div class="upsell-modal hidden" data-upsell-modal>
  <div class="upsell-modal__backdrop" data-upsell-decline></div>
  <div class="upsell-modal__body">
    <div class="upsell-modal__header-line"></div>
    <div class="upsell-modal__sparkle-icon">✨</div>
    <h3 class="upsell-modal__title">הצעה בלעדית: <br><span>אל תתנו לזיכרון להישאר לבד</span></h3>
    <p class="upsell-modal__text">גילינו שרוב הלקוחות שלנו מעדיפים לשמור צמיד אחד לעצמם ולהעניק את הצמיד השני במתנה לאדם הכי יקר להם.</p>
    
    <div class="upsell-modal__deal">
      <div class="upsell-modal__deal-info">
        <span class="upsell-modal__deal-tag">שדרוג מומלץ לזוג צמידים</span>
        <span class="upsell-modal__deal-price">₪389 בלבד <del>₪778</del></span>
      </div>
      <span class="upsell-modal__deal-badge">חיסכון של ₪389!</span>
    </div>

    <div class="upsell-modal__ctas">
      <button type="button" class="btn btn-primary btn-block" data-upsell-accept>
        כן, שדרגו אותי לזוג מרגש ב-₪389!
      </button>
      <button type="button" class="upsell-modal__decline-btn" data-upsell-decline>
        לא תודה, אני מעדיף להמשיך עם צמיד בודד
      </button>
    </div>
  </div>
</div>
{%- else -%}
  <div class="container text-center py-20" style="padding: 100px 20px; text-align: center; background: #0d0d0d; color: #fff;">
    <h2 class="gold-grad" style="font-size: 28px; margin-bottom: 15px; font-weight: 700; font-family: Heebo, sans-serif;">LumiBrace Configurator</h2>
    <p style="color: rgba(245,245,240,0.6); max-width: 500px; margin: 0 auto; font-size: 16px; font-family: Heebo, sans-serif;">
      אנא בחר מוצר להצגה במקודד/קונפיגורטור בהגדרות המקטע (או הוסף מוצר לחנות).
    </p>
  </div>
{%- endif -%}

<script>
  window.__product = {{ product | json | default: 'null' }};
</script>
<script src="{{ 'configurator.js' | asset_url }}" defer></script>

