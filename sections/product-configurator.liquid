{% comment %}
  LumiBrace Premium Product Configurator — RTL & Mobile optimized
  Natively integrates image uploads (via Shopify properties) and a fallback for WhatsApp submissions.
{% endcomment %}

{%- assign product = product | default: all_products[section.settings.product] | default: collections.all.products.first -%}

{%- if product != blank -%}
{%- assign first_variant = product.selected_or_first_available_variant -%}

<section id="design" class="py-24 bg-charcoal relative overflow-hidden" data-product>
  <div class="container mx-auto px-6">
    <div class="grid lg:grid-cols-[1.2fr_1fr] gap-16 items-start">
      
      {% comment %} Left side: Interactive Galleries & Circle Projection Previews {% endcomment %}
      <div class="space-y-8 lg:sticky lg:top-32">
      <div class="relative group">
        <div class="space-y-6">
          <div class="flex p-1 bg-pearl/5 border border-pearl/10 rounded-2xl w-fit mx-auto" role="tablist" aria-label="מצבי תצוגה">
            <button type="button" class="px-4 md:px-6 py-2 rounded-xl text-xs font-bold transition-all flex items-center gap-2 outline-none focus-visible:ring-2 focus-visible:ring-gold bg-gold text-charcoal shadow-lg gallery-toggle__btn is-active" data-gallery-tab="product" role="tab" aria-selected="true">
              הצמיד
            </button>
            <button type="button" class="px-4 md:px-6 py-2 rounded-xl text-xs font-bold transition-all flex items-center gap-2 outline-none focus-visible:ring-2 focus-visible:ring-gold text-pearl/40 hover:text-pearl gallery-toggle__btn" data-gallery-tab="projection" role="tab" aria-selected="false">
              ההקרנה
            </button>
          </div>

          <div class="relative aspect-square rounded-[2.5rem] overflow-hidden bg-black/20 border border-pearl/5 group shadow-2xl touch-pan-y product__media-wrapper">
            <div class="absolute top-4 right-4 z-20 px-3 py-1.5 bg-charcoal/70 backdrop-blur-md border border-pearl/10 rounded-full text-[11px] font-bold text-pearl/90 tracking-wider" data-gallery-counter>1 / {{ product.images.size | default: 1 }}</div>
            <div class="absolute inset-x-3 top-1/2 -translate-y-1/2 flex justify-between items-center z-20 pointer-events-none">
              <button type="button" aria-label="תמונה קודמת" class="pointer-events-auto w-10 h-10 rounded-full bg-charcoal/60 backdrop-blur-md flex items-center justify-center text-pearl hover:bg-gold hover:text-charcoal transition-colors focus-visible:ring-2 focus-visible:ring-gold outline-none" data-gallery-prev>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right w-5 h-5"><path d="m9 18 6-6-6-6"></path></svg>
              </button>
              <button type="button" aria-label="תמונה הבאה" class="pointer-events-auto w-10 h-10 rounded-full bg-charcoal/60 backdrop-blur-md flex items-center justify-center text-pearl hover:bg-gold hover:text-charcoal transition-colors focus-visible:ring-2 focus-visible:ring-gold outline-none" data-gallery-next>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left w-5 h-5"><path d="m15 18-6-6 6-6"></path></svg>
              </button>
            </div>
        {% comment %} Main product image gallery {% endcomment %}
        <div class="product__gallery" data-gallery-content="product">
          {%- if product.featured_image -%}
            <img id="product-image" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" class="w-full h-full object-cover" loading="eager" fetchpriority="high">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg w-full h-full object-cover' }}
          {%- endif -%}
        </div>

        {% comment %} Simulated circle projection preview {% endcomment %}
        <div class="product__projection hidden" data-gallery-content="projection">
          <div class="projection-box">
            <div class="projection-light-beam"></div>
            <div class="projection-cone"></div>
            <div class="projection-circle">
              <div class="projection-no-image" data-projection-placeholder>
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>
                </svg>
                <p>התמונה שלכם תוקרן כאן</p>
              </div>
              <img src="" class="projection-img hidden" data-projection-preview alt="תצוגת הקרנה">
              <div class="projection-shimmer"></div>
            </div>
            <div class="projection-badge">תצוגה מקדימה של ההקרנה</div>
          </div>
            </div>
        </div>
      </div></div>
      
      {% comment %} Thumbnails {% endcomment %}
      <div class="grid grid-cols-5 gap-2 md:gap-3 mt-6" data-gallery-thumbnails>
        {%- for image in product.images -%}
          <button type="button" class="aspect-square rounded-xl overflow-hidden border-2 transition-colors relative group thumb-btn {% if forloop.first %}border-gold shadow-lg shadow-gold/20 is-active{% else %}border-pearl/10 hover:border-gold/30{% endif %}" data-thumb-index="{{ forloop.index0 }}" data-image-url="{{ image | image_url: width: 1200 }}">
            <img src="{{ image | image_url: width: 150 }}" alt="תצוגה מקדימה {{ forloop.index }}" loading="lazy" class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity">
          </button>
        {%- endfor -%}
      </div>
      </div>

    {% comment %} Right side: Product configuration details and forms {% endcomment %}
    <div class="space-y-10">
      <div>
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-2">
            <div class="flex text-gold">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-4 h-4 fill-current"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-4 h-4 fill-current"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-4 h-4 fill-current"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-4 h-4 fill-current"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-4 h-4 fill-current"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
            </div>
            <span class="text-sm text-pearl/60">(4.9/5 מתוך 1,240 ביקורות)</span>
          </div>
          <button class="p-3 bg-pearl/5 border border-pearl/10 rounded-full text-pearl/60 hover:text-gold hover:border-gold/50 transition-all group" title="שתפו את המוצר"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-share2 lucide-share-2 w-5 h-5 group-hover:scale-110 transition-transform"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line></svg></button>
        </div>
        <div class="flex flex-col gap-2 mb-4">
          <h2 class="text-3xl md:text-6xl font-black tracking-tighter leading-tight">LumiBrace Signature<span class="block text-xl md:text-2xl font-bold text-pearl/40 mt-2 tracking-normal">צמיד הזיכרונות המקורי עם הקרנת תמונה אישית</span></h2>
        </div>
      <div class="flex items-center gap-4 mb-6">
        <span class="text-4xl md:text-6xl font-black gold-text-gradient drop-shadow-[0_0_15px_rgba(212,175,55,0.3)]" data-price>{{ first_variant.price | money }}</span>
        {%- if first_variant.compare_at_price > first_variant.price -%}
          <div class="flex flex-col">
            <span class="text-xl text-pearl/40 line-through decoration-gold/50" data-compare-price>{{ first_variant.compare_at_price | money }}</span>
            <span class="px-3 py-1 bg-gold/20 text-gold text-[10px] font-bold rounded-full uppercase tracking-wider w-fit" data-discount-badge>50% הנחה</span>
          </div>
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div class="product__desc muted">{{ product.description }}</div>
      {%- endif -%}

      <form action="/cart/add" method="post" enctype="multipart/form-data" class="configurator-form" data-product-form>
        <input type="hidden" name="id" value="{{ first_variant.id }}" data-variant-id>
        <input type="hidden" name="quantity" value="1">

        <div class="space-y-6">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold flex items-center gap-2">
              <span class="w-6 h-6 rounded-full bg-gold text-charcoal text-xs flex items-center justify-center">1</span>עצבו את הצמיד שלכם
            </h3>
          </div>

        {% comment %} Custom interactive Color & Bundle options {% endcomment %}
        {%- for option in product.options_with_values -%}
          {%- if option.name contains 'חבילה' or option.name contains 'Bundle' or option.name contains 'כמות' -%}
            <div class="space-y-4 pt-4" data-option-group-position="{{ option.position }}">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold flex items-center gap-2">
                  <span class="w-6 h-6 rounded-full bg-gold text-charcoal text-xs flex items-center justify-center">2</span>בחרו את המבצע שלכם
                </h3>
              </div>
              <div class="grid gap-4" role="radiogroup" aria-label="בחירת מבצע">
                {%- for value in option.values -%}
                  {%- assign input_id = 'opt-' | append: option.position | append: '-' | append: forloop.index -%}
                  {%- assign is_pair = false -%}
                  {%- if value contains 'זוג' or value contains 'Pair' -%}
                    {%- assign is_pair = true -%}
                  {%- endif -%}
                  <label class="p-6 rounded-[2rem] border-2 cursor-pointer transition-all flex items-center justify-between group outline-none focus-within:ring-2 focus-within:ring-gold option-pill bundle-option {% if value == option.selected_value %}border-gold bg-gold/5 is-active{% else %}border-pearl/5 hover:border-pearl/20{% endif %}" for="{{ input_id }}">
                    <input type="radio" id="{{ input_id }}" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" class="sr-only" data-option-input data-option-position="{{ option.position }}" {% if value == option.selected_value %}checked{% endif %}>
                    {%- if is_pair -%}
                      <div class="absolute top-0 left-0 bg-gold text-charcoal text-[9px] font-black px-3 py-1 rounded-br-xl uppercase tracking-tighter">הכי פופולארי</div>
                    {%- endif -%}
                    <div class="flex items-center gap-4">
                      <div class="w-6 h-6 rounded-full border-2 flex items-center justify-center transition-all bundle-radio-circle {% if value == option.selected_value %}border-gold{% else %}border-pearl/20 group-hover:border-pearl/40{% endif %}">
                        <div class="w-3 h-3 bg-gold rounded-full bundle-radio-inner {% unless value == option.selected_value %}hidden{% endunless %}"></div>
                      </div>
                      <div>
                        <p class="font-bold transition-colors bundle-title {% if value == option.selected_value %}text-gold{% else %}text-pearl{% endif %}">{{ value }}</p>
                        <p class="text-xs text-pearl/40">{% if is_pair %}אחד לך, אחד למישהו שאתה אוהב{% else %}התחלה מושלמת לזיכרון אישי{% endif %}</p>
                        {%- if is_pair -%}
                        <div class="flex items-center gap-1.5 mt-2 transition-all">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-truck w-3.5 h-3.5 text-green-400"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg>
                          <span class="text-[10px] font-bold text-green-400 uppercase tracking-tight">משלוח חינם</span>
                        </div>
                        {%- endif -%}
                      </div>
                    </div>
                    <div class="text-right">
                      {%- comment -%} We rely on JS to update real prices, but we can display fallback based on text {%- endcomment -%}
                    </div>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <div class="space-y-3" data-option-group-position="{{ option.position }}">
              <p class="text-sm font-bold text-pearl/60">{{ option.name }}:</p>
              <div class="flex gap-4">
                {%- for value in option.values -%}
                  {%- assign input_id = 'opt-' | append: option.position | append: '-' | append: forloop.index -%}
                  <label class="flex-1 p-4 rounded-2xl border-2 transition-all flex flex-col items-center gap-2 cursor-pointer outline-none focus-within:ring-2 focus-within:ring-gold option-pill {% if value == option.selected_value %}border-gold bg-gold/5 is-active{% else %}border-pearl/10 hover:border-pearl/30{% endif %}" for="{{ input_id }}">
                    <input
                      type="radio"
                      id="{{ input_id }}"
                      name="options[{{ option.name | escape }}]"
                      value="{{ value | escape }}"
                      class="sr-only"
                      data-option-input
                      data-option-position="{{ option.position }}"
                      {% if value == option.selected_value %}checked{% endif %}
                    >
                    {%- if option.name contains 'צבע' or option.name contains 'Color' -%}
                      <div class="w-8 h-8 rounded-full shadow-inner" style="background-color:{% if value contains 'כסף' or value contains 'Silver' %}#C0C0C0{% elsif value contains 'זהב' or value contains 'Gold' %}#D4AF37{% else %}#1a1a1a{% endif %}"></div>
                    {%- endif -%}
                    <span class="text-[10px] font-bold uppercase tracking-widest">{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        <input type="hidden" name="properties[אופן שליחת התמונה]" value="שליחה בוואטסאפ לאחר הרכישה">
        
        <div class="space-y-3">
          <p class="text-sm font-bold text-pearl/60">התמונה שלכם:</p>
          <div class="relative rounded-3xl border border-gold/30 bg-gradient-to-br from-gold/10 via-pearl/[0.03] to-transparent p-6 md:p-7 text-right overflow-hidden">
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-gold/10 rounded-full blur-3xl pointer-events-none"></div>
            <div class="relative flex items-start gap-4">
              <div class="shrink-0 w-12 h-12 rounded-2xl bg-gold/15 border border-gold/30 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles w-6 h-6 text-gold" aria-hidden="true"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path><path d="M20 2v4"></path><path d="M22 4h-4"></path><circle cx="4" cy="20" r="2"></circle></svg>
              </div>
              <div class="space-y-2">
                <p class="text-base font-black text-pearl leading-snug">ליווי אישי לבחירת התמונה</p>
                <p class="text-[13px] text-pearl/70 leading-relaxed">מיד לאחר ההזמנה ניצור איתכם קשר אישי בוואטסאפ או במייל, נעבור איתכם על התמונות שלכם ונבחר יחד את התמונה המושלמת — זו שתיראה הכי יפה בהקרנה על הצמיד.</p>
                <ul class="space-y-1.5 pt-1">
                  <li class="flex items-center gap-2 text-[12px] text-pearl/80">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-3.5 h-3.5 text-gold shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>יחס אישי — לא טופס אוטומטי</span>
                  </li>
                  <li class="flex items-center gap-2 text-[12px] text-pearl/80">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-3.5 h-3.5 text-gold shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>בדיקת איכות התמונה לפני ההדפסה</span>
                  </li>
                  <li class="flex items-center gap-2 text-[12px] text-pearl/80">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-3.5 h-3.5 text-gold shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>שינויים והתאמות חינם עד שתהיו מרוצים</span>
                  </li>
                </ul>
                <p class="text-[11px] text-pearl/50 pt-2 leading-relaxed">אין מה להעלות עכשיו — פשוט סיימו את ההזמנה וניצור איתכם קשר תוך 24 שעות.</p>
              </div>
            </div>
          </div>
        </div>

      {% comment %} Sizing Guide & Sizing Tips Accordions {% endcomment %}
      <div class="border border-gold/20 rounded-3xl overflow-hidden bg-gold/5">
        <details class="group [&_summary::-webkit-details-marker]:hidden">
          <summary class="w-full p-5 flex items-center justify-between hover:bg-gold/10 transition-colors cursor-pointer outline-none focus-visible:ring-2 focus-visible:ring-gold">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gold/20 flex items-center justify-center text-gold">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lightbulb w-4 h-4"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"></path><path d="M9 18h6"></path><path d="M10 22h4"></path></svg>
              </div>
              <span class="font-bold text-sm">טיפים לעיצוב מושלם</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-5 h-5 text-gold transition-transform duration-300 group-open:rotate-180"><path d="m6 9 6 6 6-6"></path></svg>
          </summary>
          <div class="p-5 pt-0 text-sm text-pearl/70 leading-relaxed font-light">
