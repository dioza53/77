<section class="section container">
  <div class="section-head">
    <h2>{{ section.settings.heading }}</h2>
  </div>
  <div class="testimonials">
    {%- for block in section.blocks -%}
      <div class="card">
        <div class="testimonial__stars">★★★★★</div>
        <p>"{{ block.settings.quote }}"</p>
        <div class="testimonial__author">— {{ block.settings.name }}{% if block.settings.location != blank %}, {{ block.settings.location }}{% endif %}</div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "מה לקוחות אומרים" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "location", "label": "Location" }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "הצמיד פשוט מושלם! התמונה יוצאת כל כך ברורה וזה מרגש כל פעם מחדש.", "name": "דנה לוי", "location": "תל אביב" } },
        { "type": "testimonial", "settings": { "quote": "קניתי לאשתי ליום הנישואין והיא בכתה מהתרגשות. שירות מעולה!", "name": "אבי כהן", "location": "חיפה" } },
        { "type": "testimonial", "settings": { "quote": "איכות מדהימה. רואים שזה מוצר פרימיום ולא סתם עוד תכשיט.", "name": "מאיה גולדשטיין", "location": "רעננה" } }
      ]
    }
  ]
}
{% endschema %}
