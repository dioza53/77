{% comment %}
  LumiBrace UGC Gallery Section — customizable customer photos and review overlays
{% endcomment %}

<section class="py-24 bg-charcoal relative overflow-hidden">
  <div class="absolute top-0 right-0 w-full h-px bg-gradient-to-r from-transparent via-gold/20 to-transparent"></div>
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
      <span class="px-4 py-1.5 rounded-full bg-gold/10 text-gold text-xs font-bold uppercase tracking-widest inline-block mb-4 border border-gold/20 shadow-[0_0_15px_rgba(212,175,55,0.2)]">{{ section.settings.badge }}</span>
      <h2 class="text-3xl md:text-5xl font-black text-pearl tracking-tight">{{ section.settings.heading }}</h2>
      <p class="text-pearl/60 text-lg max-w-2xl mx-auto">{{ section.settings.subheading }}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
      {%- for block in section.blocks -%}
        <div class="group relative rounded-[2rem] overflow-hidden aspect-[4/5] bg-pearl/5 border border-pearl/10 cursor-pointer" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="תמונת לקוח {{ block.settings.name }}" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
          {%- else -%}
            <div class="w-full h-full bg-pearl/10 flex items-center justify-center transition-transform duration-700 group-hover:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image text-pearl/20"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path></svg>
            </div>
          {%- endif -%}

          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity"></div>
          
          <div class="absolute inset-0 p-6 flex flex-col justify-end translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <div class="flex items-center gap-1 mb-3">
              {%- for i in (1..block.settings.rating) -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="w-4 h-4 text-gold drop-shadow-[0_0_8px_rgba(212,175,55,0.8)]"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
              {%- endfor -%}
            </div>
            <p class="text-pearl font-bold text-lg mb-2">{{ block.settings.name }}</p>
            <p class="text-pearl/80 text-sm leading-relaxed line-clamp-3 group-hover:line-clamp-none transition-all duration-500">"{{ block.settings.review_text }}"</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "UGC Gallery",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "קהילה של זיכרונות" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "רגעים אמיתיים של לקוחות" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "הצטרפו לאלפי לקוחות שכבר שומרים את הזיכרונות שלהם קרוב ללב." }
  ],
  "blocks": [
    {
      "type": "ugc_item",
      "name": "Customer Review",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Customer Photo" },
        { "type": "text", "id": "name", "label": "Customer Name", "default": "נועה & איתי" },
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "default": 5 },
        { "type": "textarea", "id": "review_text", "label": "Review Text", "default": "השקיעה על האגם בקומו - הרגע שבו ידעתי שזה הוא. עכשיו הוא איתי תמיד על היד." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "UGC Gallery",
      "blocks": [
        { "type": "ugc_item", "settings": { "name": "נועה & איתי", "review_text": "השקיעה על האגם בקומו - הרגע שבו ידעתי שזה הוא. עכשיו הוא איתי תמיד." } },
        { "type": "ugc_item", "settings": { "name": "שירה & דניאל", "review_text": "ירח דבש במלדיביים, אחרי שנתיים שחיכינו לזה. הרגע הזה שווה הכל." } },
        { "type": "ugc_item", "settings": { "name": "תמר & יונתן", "review_text": "החיבוק הראשון שלנו מול הים בנעורים. הזיכרון הזה נמצא איתי בכל יום." } },
        { "type": "ugc_item", "settings": { "name": "ליאל & עומר", "review_text": "סלפי ספונטני בדרך הביתה, צוחקים על שטות. הכי טוב כשזה הכי פשוט." } },
        { "type": "ugc_item", "settings": { "name": "מאיה & יואב", "review_text": "ערב ראש השנה בריו, זיקוקים מעלינו ונשיקה אחת ארוכה. בלתי נשכח." } },
        { "type": "ugc_item", "settings": { "name": "רוני & אדם", "review_text": "לילה בחוף, רק אנחנו והירח. הצמיד הזה הוא הסוד הקטן שלנו." } }
      ]
    }
  ]
}
{% endschema %}
