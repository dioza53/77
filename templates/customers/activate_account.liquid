<section class="section container" style="max-width:480px"><h1>הפעלת חשבון</h1>{% form 'activate_customer_password' %}{{ form.errors | default_errors }}<input type="password" name="customer[password]" placeholder="סיסמה" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><input type="password" name="customer[password_confirmation]" placeholder="אימות סיסמה" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><button type="submit" class="btn btn-primary btn-block">הפעל</button>{% endform %}</section>
