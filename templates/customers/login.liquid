<section class="section container" style="max-width:480px"><h1>התחברות</h1>{% form 'customer_login' %}{{ form.errors | default_errors }}<input type="email" name="customer[email]" placeholder="אימייל" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><input type="password" name="customer[password]" placeholder="סיסמה" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><button type="submit" class="btn btn-primary btn-block">היכנס</button>{% endform %}<p><a href="/account/register">צור חשבון</a></p></section>
