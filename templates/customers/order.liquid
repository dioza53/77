<section class="section container"><h1>הזמנה {{ order.name }}</h1><p>תאריך: {{ order.created_at | date: '%d/%m/%Y' }}</p><p>סטטוס: {{ order.fulfillment_status_label }}</p>{% for line in order.line_items %}<div class="card" style="margin-bottom:12px"><strong>{{ line.title }}</strong> × {{ line.quantity }} — {{ line.final_line_price | money }}</div>{% endfor %}<p><strong>סך הכל: {{ order.total_price | money }}</strong></p></section>
