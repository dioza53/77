<section class="section container" style="max-width:480px"><h1>הרשמה</h1>{% form 'create_customer' %}{{ form.errors | default_errors }}<input type="text" name="customer[first_name]" placeholder="שם פרטי" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><input type="text" name="customer[last_name]" placeholder="שם משפחה" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><input type="email" name="customer[email]" placeholder="אימייל" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><input type="password" name="customer[password]" placeholder="סיסמה" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><button type="submit" class="btn btn-primary btn-block">הירשם</button>{% endform %}</section>
