<section class="section container" style="max-width:480px"><h1>איפוס סיסמה</h1>{% form 'recover_customer_password' %}{{ form.errors | default_errors }}{% if form.posted_successfully? %}<p class="gold">נשלח אימייל לאיפוס.</p>{% endif %}<input type="email" name="email" placeholder="אימייל" required style="width:100%;padding:12px;margin:8px 0;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)"><button type="submit" class="btn btn-primary btn-block">שלח</button>{% endform %}</section>
