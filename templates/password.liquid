{% layout 'password' %}
<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px">
  <div class="container text-center">
    <h1 class="gold-grad">{{ shop.name }}</h1>
    <p class="muted">בקרוב.</p>
    {% form 'storefront_password' %}
      <input type="password" name="password" placeholder="סיסמה" style="padding:12px;border-radius:12px;background:rgba(245,245,240,0.06);color:var(--text);border:1px solid var(--border)">
      <button type="submit" class="btn btn-primary">היכנס</button>
    {% endform %}
  </div>
</body>
</html>
